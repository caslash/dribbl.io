# Backend URL used by the Vite dev server proxy
BACKEND_URL=http://localhost:3001

# Backend URL exposed to client code (Socket.io + fetch).
# Leave empty in development (Vite proxy handles it).
# Set to the full backend URL in production (e.g. https://api.dribbl.io).
VITE_BACKEND_URL=

# Path prefix for team logo SVGs (served from /public/logos)
VITE_LOGO_SVG_PATH=/logos
